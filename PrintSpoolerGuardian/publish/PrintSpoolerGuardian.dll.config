<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <configSections>
    <section name="printGuardian" type="System.Configuration.NameValueSectionHandler" />
  </configSections>

  <printGuardian>
    <!-- Polling interval in seconds -->
    <add key="PollIntervalSeconds" value="30" />
    <!-- How long before a stuck job triggers recovery (seconds) -->
    <add key="StaleJobThresholdSeconds" value="300" />
    <!-- How old a spool file must be before cleanup (seconds) -->
    <add key="StaleFileThresholdSeconds" value="300" />
    <!-- Cooldown between full recovery cycles (minutes) -->
    <add key="CooldownMinutes" value="10" />
    <!-- Max recovery attempts per hour -->
    <add key="MaxRecoveriesPerHour" value="3" />
    <!-- Timeout for spooler stop/start (seconds each) -->
    <add key="SpoolerTimeoutSeconds" value="60" />
    <!-- Wait after USB device toggle (seconds) -->
    <add key="UsbResetWaitSeconds" value="15" />
    <!-- Wait between escalation steps (seconds) -->
    <add key="StepWaitSeconds" value="5" />
    <!-- Log file directory -->
    <add key="LogDirectory" value="C:\ProgramData\PrintSpoolerGuardian" />
    <!-- Semicolon-separated list of USB printer names to watch.
         Leave empty or omit = ALL USB printers are monitored automatically. -->
    <add key="WatchedPrinters" value="" />
    <!-- Auto-update: GitHub releases URL (owner/repo format, e.g. "YourOrg/PrintSpoolerGuardian")
         Leave empty to disable auto-updates. -->
    <add key="UpdateGitHubRepo" value="BobanAliBrz/PrinterResetAliBrz" />
    <!-- How often to check for updates, in hours (0 = disabled) -->
    <add key="UpdateCheckIntervalHours" value="24" />
  </printGuardian>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
</configuration>